---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

type Entry = CollectionEntry<'posts'> | CollectionEntry<'travel'>;

interface Props {
  entry: Entry;
  eyebrow?: string;
}

const { entry, eyebrow } = Astro.props;
const { title, publishedAt, cover, coverAlt, excerpt } = entry.data;
const formatted = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Prev/next within the same collection, sorted by date desc.
const siblings = (
  await getCollection(entry.collection, ({ data }) => !data.draft)
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const idx = siblings.findIndex((s) => s.slug === entry.slug);
const newer = idx > 0 ? siblings[idx - 1] : null;
const older = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;

const hrefFor = (e: Entry) => `/${e.collection}/${e.slug}/`;
---

<BaseLayout
  title={title}
  description={excerpt}
  image={cover}
  type="article"
>
  <article>
    <header class="post-header reading">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="muted byline">
        <time datetime={publishedAt.toISOString()}>{formatted}</time>
      </p>
    </header>

    {
      cover && (
        <figure class="cover wide">
          <img
            src={cover}
            alt={coverAlt ?? ''}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </figure>
      )
    }

    <div class="post-body reading">
      <slot />
    </div>

    {(newer || older) && (
      <nav class="post-nav reading" aria-label="More posts">
        {older ? (
          <a class="prev" href={hrefFor(older)}>
            <span class="dir">← Older</span>
            <span class="title">{older.data.title}</span>
          </a>
        ) : <span />}
        {newer ? (
          <a class="next" href={hrefFor(newer)}>
            <span class="dir">Newer →</span>
            <span class="title">{newer.data.title}</span>
          </a>
        ) : <span />}
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  article {
    padding: 3rem 0 1rem;
  }

  .post-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .post-header h1 {
    margin: 0.6rem 0 0.4rem;
  }

  .byline {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
  }

  .cover {
    margin: 0 auto 3rem;
  }
  .cover img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    background: var(--bg-elevated);
    border-radius: 4px;
  }

  .post-body :global(h2),
  .post-body :global(h3) {
    margin-top: 2.2em;
  }

  .post-nav {
    margin: 3rem auto 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .post-nav a {
    display: block;
    color: var(--ink);
    text-decoration: none;
  }
  .post-nav .next {
    text-align: right;
  }
  .post-nav .dir {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--ink-soft);
    margin-bottom: 0.2rem;
  }
  .post-nav .title {
    font-size: var(--step-0);
  }
  .post-nav a:hover .title {
    color: var(--accent);
  }
</style>
