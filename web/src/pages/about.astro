---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section class="reading">
    <header class="head">
      <p class="eyebrow">About</p>
      <h1>Maker of things big and small</h1>
    </header>

    <p>
      I'm Parker. This is a quiet corner of the internet where I keep notes
      about places I've been, things I've built, and ideas I'm working through.
    </p>

    <p>
      Find me on <a href="https://github.com/psmithdev">GitHub</a> or
      <a href="https://linkedin.com/in/parkersmith1/">LinkedIn</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .head {
    padding: 3rem 0 1rem;
  }
  .head h1 {
    margin: 0.4rem 0 1.5rem;
  }
</style>
