---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const essays = (
  await getCollection('posts', ({ data }) => !data.draft && data.category !== 'making')
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<BaseLayout title="Essays" description="Essays on travel, ideas, and what Parker is learning along the way.">
  <section class="reading">
    <header class="head">
      <p class="eyebrow">Writing</p>
      <h1>Essays</h1>
    </header>

    {
      essays.length === 0 ? (
        <p class="muted">No essays yet.</p>
      ) : (
        <ul class="list">
          {essays.map((e) => (
            <li>
              <a href={`/posts/${e.slug}/`}>
                <p class="eyebrow">{fmt(e.data.publishedAt)}</p>
                <h2>{e.data.title}</h2>
                {e.data.excerpt && <p class="muted">{e.data.excerpt}</p>}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .head {
    padding: 3rem 0 1.5rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 2rem;
  }
  .head h1 {
    margin: 0.2rem 0 0;
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .list li {
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .list a {
    display: block;
    color: var(--ink);
    text-decoration: none;
  }
  .list h2 {
    font-size: var(--step-2);
    margin: 0.2rem 0 0.4rem;
  }
  .list a:hover h2 {
    color: var(--accent);
  }
</style>
