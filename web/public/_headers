/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), browsing-topics=(), geolocation=(), microphone=(), camera=()
  X-Frame-Options: SAMEORIGIN
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' https://assets.psmith.dev https://*.basemaps.cartocdn.com data:; media-src 'self' https://assets.psmith.dev; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.basemaps.cartocdn.com; frame-src https://felt.com; child-src https://felt.com; font-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests

# Long-cache hashed Astro build assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
